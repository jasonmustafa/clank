# Discord secrets/config. Copy to .env; never commit .env.
DISCORD_TOKEN=replace-me
DISCORD_CLIENT_ID=

# Required: comma/space separated Discord user IDs allowed to talk to Clank.
DISCORD_ALLOWED_USER_IDS=

# Guild messages are rejected unless the guild is listed here. DMs use DISCORD_ALLOW_DMS.
DISCORD_ALLOWED_GUILD_IDS=

# Optional channel allowlist. If set, guild messages must be in one of these channels
# or in a thread whose parent is one of these channels.
DISCORD_ALLOWED_CHANNEL_IDS=

DISCORD_ALLOW_DMS=true

# If false, guild channel messages must mention the bot or use a command prefix.
# If true, any message in an allowlisted guild/channel can start a job.
DISCORD_ALLOW_GUILD_CHANNEL_MESSAGES=false
CLANK_COMMAND_PREFIXES=!,/

# Pi/Clank paths
PI_AGENT_DIR=/opt/clank/pi-agent
PI_SESSION_DIR=/opt/clank/pi-sessions
CLANK_WORKSPACE_ROOT=/opt/clank/workspaces
CLANK_APP_DIR=/opt/clank/app
# Master filesystem allowlist. Comma or whitespace separated. Workspace root is always allowed.
# If unset, defaults to CLANK_WORKSPACE_ROOT plus CLANK_APP_DIR and PI_AGENT_DIR.
# CLANK_ALLOWED_ROOTS=/opt/clank/app,/opt/clank/pi-agent,/data/example-notes,/opt/clank/repos,/opt/clank/worktrees
CLANK_ALLOWED_ROOTS=
CLANK_STATE_DIR=/opt/clank/state
CLANK_TEMP_DIR=/opt/clank/tmp

# Runner: sdk now; rpc/container-rpc/microvm-rpc are placeholders.
CLANK_RUNNER=sdk

CLANK_MAX_ATTACHMENT_BYTES=26214400
CLANK_PREVIEW_THROTTLE_MS=1500
CLANK_CONFIRM_TIMEOUT_MS=60000

# Temporary route diagnostics. When enabled, logs Discord message routing metadata and
# message previews to CLANK_ROUTE_DEBUG_LOG or CLANK_STATE_DIR/message-route-debug.log.
CLANK_ROUTE_DEBUG=false
CLANK_ROUTE_DEBUG_LOG=
